# caida_100 (104 nodes, 40 RPKI) — dataset-specific overrides
# Tuned 2026-04-16 based on caida_1600 validation: timeouts 3× prior, pending cap
# lowered to reduce event-loop iteration cost, warmup extended for KB density.
P2P_REGULAR_TIMEOUT=25
P2P_ATTACK_TIMEOUT=40
P2P_MAX_BROADCAST_PEERS=6
KNOWLEDGE_WINDOW_SECONDS=600
KNOWLEDGE_CLEANUP_INTERVAL=60
INGESTION_BUFFER_MAX_SIZE=800
PENDING_VOTES_MAX_CAPACITY=3000
COMMITTED_TX_MAX_SIZE=40000
COMMITTED_TX_CLEANUP_INTERVAL=300
KNOWLEDGE_BASE_MAX_SIZE=40000
LAST_SEEN_CACHE_MAX_SIZE=80000
BATCH_SIZE=3
WARMUP_DURATION=450
SIMULATION_SPEED_MULTIPLIER=1.0
SIM_DURATION=2100
