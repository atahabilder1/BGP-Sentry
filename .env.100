# =============================================================================
# BGP-Sentry Configuration — 100 Nodes (caida_bfs_174_100)
# =============================================================================

# ── Consensus & P2P Network ──
CONSENSUS_MIN_SIGNATURES=2
CONSENSUS_CAP_SIGNATURES=2
P2P_REGULAR_TIMEOUT=14
P2P_ATTACK_TIMEOUT=21
# NOTE: P2P_MAX_BROADCAST_PEERS is NOT used in code — broadcast size is
# computed dynamically as max(threshold*2, sqrt(N_rpki_validators)).
# At 38 validators, sqrt(38)=6 → broadcast=6.
P2P_MAX_BROADCAST_PEERS=6
P2P_BASE_PORT=8000

# ── Deduplication ──
RPKI_DEDUP_WINDOW=15
NONRPKI_DEDUP_WINDOW=10
SAMPLING_WINDOW_SECONDS=300

# ── Knowledge Base ──
# Wider window gives peers more time to accumulate observations before voting
KNOWLEDGE_WINDOW_SECONDS=600
KNOWLEDGE_CLEANUP_INTERVAL=60

# ── Buffer & Capacity Limits ──
INGESTION_BUFFER_MAX_SIZE=800
PENDING_VOTES_MAX_CAPACITY=4000
COMMITTED_TX_MAX_SIZE=40000
COMMITTED_TX_CLEANUP_INTERVAL=300
KNOWLEDGE_BASE_MAX_SIZE=40000
LAST_SEEN_CACHE_MAX_SIZE=80000

# ── Attack Detection ──
FLAP_WINDOW_SECONDS=60
FLAP_THRESHOLD=5
FLAP_DEDUP_SECONDS=2
ATTACK_CONSENSUS_MIN_VOTES=3
ATTACK_CONSENSUS_REWARD_DETECTION=10
ATTACK_CONSENSUS_REWARD_CORRECT_VOTE=2
ATTACK_CONSENSUS_PENALTY_FALSE_ACCUSATION=-20

# ── BGPCoin Economy ──
BGPCOIN_TOTAL_SUPPLY=10000000
BGPCOIN_REWARD_BLOCK_COMMIT=10
BGPCOIN_REWARD_VOTE_APPROVE=1
BGPCOIN_REWARD_FIRST_COMMIT_BONUS=5
BGPCOIN_REWARD_ATTACK_DETECTION=100
BGPCOIN_REWARD_DAILY_MONITORING=10
BGPCOIN_PENALTY_FALSE_REJECT=2
BGPCOIN_PENALTY_FALSE_APPROVE=5
BGPCOIN_PENALTY_MISSED_PARTICIPATION=1
BGPCOIN_MULTIPLIER_ACCURACY_MIN=0.5
BGPCOIN_MULTIPLIER_ACCURACY_MAX=1.5
BGPCOIN_MULTIPLIER_PARTICIPATION_MIN=0.8
BGPCOIN_MULTIPLIER_PARTICIPATION_MAX=1.2
BGPCOIN_MULTIPLIER_QUALITY_MIN=0.9
BGPCOIN_MULTIPLIER_QUALITY_MAX=1.3

# ── Non-RPKI Trust Rating ──
RATING_INITIAL_SCORE=50
RATING_MIN_SCORE=0
RATING_MAX_SCORE=100
RATING_PENALTY_PREFIX_HIJACK=-20
RATING_PENALTY_SUBPREFIX_HIJACK=-18
RATING_PENALTY_BOGON_INJECTION=-25
RATING_PENALTY_ROUTE_FLAPPING=-10
RATING_PENALTY_ROUTE_LEAK=-15
RATING_PENALTY_FORGED_ORIGIN=-30
RATING_PENALTY_ACCIDENTAL_ROUTE_LEAK=-8
RATING_PENALTY_REPEATED_ATTACK=-30
RATING_PENALTY_PERSISTENT_ATTACKER=-50
RATING_REWARD_MONTHLY_GOOD_BEHAVIOR=5
RATING_REWARD_FALSE_ACCUSATION_CLEARED=2
RATING_REWARD_PER_100_LEGITIMATE=1
RATING_REWARD_HIGHLY_TRUSTED_BONUS=10
RATING_THRESHOLD_HIGHLY_TRUSTED=90
RATING_THRESHOLD_TRUSTED=70
RATING_THRESHOLD_NEUTRAL=50
RATING_THRESHOLD_SUSPICIOUS=30

# ── Transaction Batching ──
BATCH_SIZE=30
BATCH_TIMEOUT=0.2

# ── Simulation ──
# Goal for caida_100: REAL-TIME (multiplier=1.0). This is the smallest
# topology — target is that the simulator keeps up with wall clock so we
# can claim "real-time BGP monitoring".
SIMULATION_SPEED_MULTIPLIER=1.0

# Wall-clock cap for main_experiment.py --duration.
# Must cover the full dataset timestamp span + drain overhead.
# caida_100 dataset span = ~1167s → 1250 gives ~80s drain headroom.
SIM_DURATION=1250

USE_ASYNC=true

# Warm-up: listen-only phase to build knowledge base before consensus
WARMUP_DURATION=60
