# caida_1600 (1627 nodes, 778 RPKI) — dataset-specific overrides
P2P_REGULAR_TIMEOUT=90
P2P_ATTACK_TIMEOUT=135
P2P_MAX_BROADCAST_PEERS=28
KNOWLEDGE_WINDOW_SECONDS=1800
KNOWLEDGE_CLEANUP_INTERVAL=60
INGESTION_BUFFER_MAX_SIZE=10000
PENDING_VOTES_MAX_CAPACITY=15000
COMMITTED_TX_MAX_SIZE=500000
COMMITTED_TX_CLEANUP_INTERVAL=300
KNOWLEDGE_BASE_MAX_SIZE=500000
LAST_SEEN_CACHE_MAX_SIZE=1000000
BATCH_SIZE=4
# caida_1600-specific: longer warm-up overrides .env.common (600s vs 300s)
# Justification: at N=778 RPKI validators, denser direct-observation seeding
# per validator is needed before active consensus starts (see DATASET_REVISION.md
# §Warm-up scaling).
WARMUP_DURATION=600
SIMULATION_SPEED_MULTIPLIER=1.0
SIM_DURATION=3600
